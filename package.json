{
  "name": "yy-pay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next build && next start",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate:api:payment": "openapi-typescript ./openapi/openapi-payment.json -o ./src/types/schemas-payment.d.ts",
    "generate:api:auth": "openapi-typescript ./openapi/openapi-auth.json -o ./src/types/schemas-auth.d.ts",
    "generate:api": "npm run generate:api:payment && npm run generate:api:auth",
    "prebuild": "npm run generate:api"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.14.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "openapi-typescript": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
